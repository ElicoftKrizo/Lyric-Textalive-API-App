{
  "name": "cotodama-lyric-speaker",
  "version": "1.1.0",
  "description": "Minimalist 3D kinetic lyric visualization desktop app inspired by Cotodama Lyric Speaker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "textalive-app-api": "0.4.0",
    "three": "^0.163.0"
  },
  "optionalDependencies": {
    "airplay-server": "^1.1.0",
    "speaker": "^0.5.5"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cotodama.lyricspeaker",
    "productName": "Lyric Speaker",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "mood-engine.js",
      "node_modules/three/build/three.module.js",
      "node_modules/textalive-app-api/dist/index.js"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "electron",
    "threejs",
    "textalive",
    "lyric",
    "visualization",
    "cotodama"
  ],
  "author": "Eli",
  "license": "MIT"
}
